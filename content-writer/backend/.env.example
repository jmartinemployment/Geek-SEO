# Content Writer API — copy to .env in this folder or Geek-SEO repo root (DotNetEnv traverses upward).
#
# Supabase Postgres (production and shared dev).
# Use the DIRECT connection URI from Supabase → Project Settings → Database (port 5432).
# For EF migrations, avoid the transaction pooler (port 6543).
# CONTENT_WRITER_DATABASE_URL takes precedence over DATABASE_URL.
CONTENT_WRITER_DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres?sslmode=require
#
# Or reuse the platform DATABASE_URL (same Supabase instance as GeekRepository / geek_seo schema):
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres?sslmode=require

# Local API
ASPNETCORE_ENVIRONMENT=Development
# ASPNETCORE_URLS=http://localhost:5199
