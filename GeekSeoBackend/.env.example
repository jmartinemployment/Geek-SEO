# Geek SEO data gateway (server-to-server only — not the browser)
REPO_URL=https://geekrepository-production.up.railway.app

# OAuth: own machine client (NOT geekapi — that secret is GeekAPI-only)
GEEK_OAUTH_AUTHORITY=https://api.geekatyourspot.com
GEEK_SEO_BACKEND_CLIENT_SECRET=change-me-geekseo-backend-secret

# Local only — when GeekRepository runs without JWT validation (Development)
# REPO_API_KEY=

# User JWT validation (browser tokens)
# JWT_KEY=base64-signing-key
# JWT_ISSUER=
# JWT_AUDIENCE=geekseo

# SERP / AI providers (GeekRepository may also need these when scoring runs there)
# DATAFORSEO_LOGIN=
# DATAFORSEO_PASSWORD=
# ANTHROPIC_API_KEY=

CORS_ORIGINS=http://localhost:3000
PORT=5051
