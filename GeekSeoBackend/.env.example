# GeekSeoBackend — product API (not the browser, not GeekRepository)

# Issuer: standard JWT validation (Authority + Audience)
GEEK_OAUTH_AUTHORITY=https://api.geekatyourspot.com
JWT_AUDIENCE=geekseo

# Data gateway: GeekAPI internal routes only (user Bearer forwarded)
GEEK_API_URL=https://api.geekatyourspot.com

# Do NOT set REPO_URL, DATABASE_URL, or any GeekRepository URL on this service.

# GeekAPI internal gateway (same key GeekAPI expects for /api/seo/internal/*)
GEEK_BACKEND_API_KEY=
JWT_AUDIENCE=geekseo

# SEO data providers (defaults = dataforseo — see plan-documents/SEO-PROVIDER-STRATEGY.md)
# SERP_PROVIDER=dataforseo          # dataforseo | serpapi | geek (geek requires Phase C)
# KEYWORD_PROVIDER=dataforseo       # dataforseo | gsc_ads | geek
# RANK_SNAPSHOT_PROVIDER=dataforseo # dataforseo | serpapi | geek
# SERP_PROVIDER_FALLBACK=             # Phase A: optional dataforseo fallback chain
# SERPAPI_API_KEY=
# Ops: optional monthly SerpApi spend alert target (documentation only until alerting ships)
# SERPAPI_MONTHLY_BUDGET_USD=100

# External providers (required for live SERP/scoring — returns explicit errors if unset)
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
ANTHROPIC_API_KEY=

# Google integrations (GSC + GA4)
# Required in production startup:
#   GOOGLE_CLIENT_ID
#   GOOGLE_CLIENT_SECRET
#   GOOGLE_REDIRECT_URI
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Public homepage scan — Google PageSpeed Insights API (optional)
# Create key: Google Cloud Console → APIs & Services → PageSpeed Insights API → Credentials → API key
# Application restrictions: None (server-side). API restrictions: PageSpeed Insights API only.
# Without this key, GET /api/public/scan still returns on-page signals; Lighthouse scores are omitted.
GOOGLE_PSI_API_KEY=

# Frontend URL for OAuth callback redirect (defaults to first CORS_ORIGINS origin)
# GEEKSEO_APP_URL=https://seo.geekatyourspot.com

# Optional: disable Playwright competitor crawl (uses NoOpCrawlerProvider)
# DISABLE_PLAYWRIGHT=true

# Plagiarism (Copyscape) — OPTIONAL; editor panel shows "not configured" without these
COPYSCAPE_USERNAME=
COPYSCAPE_API_KEY=
# COPYSCAPE_SPEND_LIMIT_USD=0.50

CORS_ORIGINS=http://localhost:3000
PORT=5051

# PayPal subscriptions (OPTIONAL — checkout deferred until plans exist)
# Client credentials: PayPal Developer → your sandbox/live app (same as OrderStack is fine).
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_ENVIRONMENT=sandbox

# These four IDs do NOT exist in PayPal's UI — create them once via API:
#   node scripts/paypal-create-subscription-plans.mjs
# Then paste the printed P-... values here:
# PAYPAL_PLAN_STARTER=
# PAYPAL_PLAN_PROFESSIONAL=
# PAYPAL_PLAN_TEAM=
# PAYPAL_PLAN_AGENCY=
#
# See docs/PAYPAL-BILLING.md

# Your login gets full access (same env on Railway production). Comma-separated GeekOAuth emails.
# Production: jmartinemployment@gmail.com — TODO later: add @geekatyourspot.com service account email
SUBSCRIPTION_FULL_ACCESS_EMAILS=jmartinemployment@gmail.com
# Optional: grant full access by user id (useful for X-User-Id integration tests / SITE_AUDIT_LIVE=1)
# SUBSCRIPTION_FULL_ACCESS_USER_IDS=00000000-0000-0000-0000-000000000001

# Optional: set tier without PayPal (staging only — not needed if FULL_ACCESS_EMAILS is set)
# SUBSCRIPTION_MANUAL_TIER_ENABLED=true

# Scheduled maintenance worker (topical map refresh, published snapshots, GEO probes, content guard)
# Value = GeekOAuth asp_net_users.id (JWT sub). NOT Supabase auth.users.
# Lookup: GeekOAuth Railway Postgres → SELECT id, email FROM asp_net_users;
# Production (2026-05-31): jmartinemployment@gmail.com → 92b274f5-2fcb-4935-ba2d-cd8c03e1b21b
# TODO later: create @geekatyourspot.com service account and replace this id on Railway.
WORKER_SERVICE_USER_ID=
