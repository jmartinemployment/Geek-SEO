# GeekSeoBackend — product API (not the browser, not GeekRepository)

# Issuer: standard JWT validation (Authority + Audience)
GEEK_OAUTH_AUTHORITY=https://api.geekatyourspot.com
JWT_AUDIENCE=geekseo

# Data gateway: GeekAPI internal routes only (user Bearer forwarded)
GEEK_API_URL=https://api.geekatyourspot.com

# Do NOT set REPO_URL, DATABASE_URL, or any GeekRepository URL on this service.

# GeekAPI internal gateway (same key GeekAPI expects for /api/seo/internal/*)
GEEK_BACKEND_API_KEY=
JWT_AUDIENCE=geekseo

# External providers (required for live SERP/scoring — returns explicit errors if unset)
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
ANTHROPIC_API_KEY=

# Google integrations (GSC + GA4)
# Required in production startup:
#   GOOGLE_CLIENT_ID
#   GOOGLE_CLIENT_SECRET
#   GOOGLE_REDIRECT_URI
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Public homepage scan — Google PageSpeed Insights API (optional)
# Create key: Google Cloud Console → APIs & Services → PageSpeed Insights API → Credentials → API key
# Application restrictions: None (server-side). API restrictions: PageSpeed Insights API only.
# Without this key, GET /api/public/scan still returns on-page signals; Lighthouse scores are omitted.
GOOGLE_PSI_API_KEY=

# Frontend URL for OAuth callback redirect (defaults to first CORS_ORIGINS origin)
# GEEKSEO_APP_URL=https://seo.geekatyourspot.com

# Optional: disable Playwright competitor crawl (uses NoOpCrawlerProvider)
# DISABLE_PLAYWRIGHT=true

CORS_ORIGINS=http://localhost:3000
PORT=5051

# PayPal subscriptions (optional — pricing page shows disabled state until configured)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
# sandbox (default) or live
PAYPAL_ENVIRONMENT=sandbox
PAYPAL_PLAN_STARTER=
PAYPAL_PLAN_PROFESSIONAL=
PAYPAL_PLAN_TEAM=
PAYPAL_PLAN_AGENCY=
# Webhook URL (configure in PayPal developer dashboard):
# POST https://<geekseo-backend>/api/seo/subscription/webhooks/paypal
