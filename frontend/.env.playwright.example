# Copy to .env.playwright.local (gitignored) for authenticated E2E.
# Use a dedicated GeekOAuth test user — no 2FA — with access to production Geek SEO.

PLAYWRIGHT_TEST_EMAIL=your-test-user@example.com
PLAYWRIGHT_TEST_PASSWORD=your-password-here

